{
  "name": "neo-quota-monitor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "vite",
    "test": "bun scripts/with-rustup-path.mjs cargo test --manifest-path src-tauri/Cargo.toml",
    "build": "tsc && vite build",
    "desktop:dev": "bun scripts/with-rustup-path.mjs tauri dev",
    "desktop:build": "bun scripts/with-rustup-path.mjs tauri build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@vitejs/plugin-react": "^6.0.1",
    "lucide-react": "^0.468.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "vite": "^8.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tauri-apps/cli": "^2.11.2",
    "@types/bun": "^1.3.4",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  }
}
