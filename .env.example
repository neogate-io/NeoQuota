# CPA Quota Monitor environment example
# Copy this file to .env, then replace placeholder secrets before deployment.

# -----------------------------------------------------------------------------
# Required: monitor login and service basics
# -----------------------------------------------------------------------------
MONITOR_KEY=change-this-monitor-password
HOST=127.0.0.1
PORT=8787
DB_PATH=./data/quota-monitor.sqlite

# Set true only when the monitor is accessed through HTTPS.
# Keep false for plain HTTP / LAN IP access, otherwise login cookies will not work.
COOKIE_SECURE=false

# -----------------------------------------------------------------------------
# CPA target: single CPA mode
# If CPA_TARGETS below is enabled, it replaces these single CPA variables.
# -----------------------------------------------------------------------------
CPA_ID=default
CPA_NAME=Default CPA
CPA_API_BASE=http://154.21.88.164:8398
CPA_MANAGEMENT_KEY=change-this-cpa-management-key

# -----------------------------------------------------------------------------
# CPA target: multi CPA mode
# Uncomment CPA_TARGETS to manage multiple CPA services from one monitor.
# Keep the JSON on one line for most .env parsers.
# -----------------------------------------------------------------------------
# CPA_TARGETS=[{"id":"main","name":"Main CPA","apiBase":"http://154.21.88.164:8398","managementKey":"key-a"},{"id":"backup","name":"Backup CPA","apiBase":"http://127.0.0.1:8398","managementKey":"key-b"}]

# -----------------------------------------------------------------------------
# Collection strategy: low-risk automatic patrol
# -----------------------------------------------------------------------------
COLLECT_USAGE_MODE=continuous
COLLECT_USAGE_TICK_SECONDS=180
COLLECT_USAGE_MAX_REQUESTS_PER_MINUTE=2
COLLECT_CONCURRENCY=2
COLLECT_USAGE_NORMAL_MIN_INTERVAL_MINUTES=90
COLLECT_USAGE_HOT_MIN_INTERVAL_MINUTES=30
COLLECT_USAGE_MAX_STALENESS_MINUTES=120
COLLECT_USAGE_JITTER_SECONDS=45

# Manual "smart collect": full-pool, small-batch, staggered completion
COLLECT_MANUAL_CONCURRENCY=10
COLLECT_MANUAL_MAX_REQUESTS_PER_MINUTE=10

# Error handling and API timeout
COLLECT_USAGE_ERROR_BACKOFF_MINUTES=10
COLLECT_USAGE_ERROR_BACKOFF_MAX_MINUTES=120
CPA_REQUEST_TIMEOUT_SECONDS=60
CACHE_TRUST_MAX_MINUTES=60

# -----------------------------------------------------------------------------
# Consumption windows and legacy/adaptive collection knobs
# Usually leave these unchanged when COLLECT_USAGE_MODE=continuous.
# -----------------------------------------------------------------------------
COLLECT_INTERVAL_MINUTES=15
COLLECT_SAMPLE_PERCENT=20
COLLECT_MAX_STALE_MINUTES=120
COLLECT_NEW_ACCOUNT_BURST=20
COLLECT_CONSUMPTION_SAMPLE_PERCENT=60
COLLECT_CONSUMPTION_WINDOW_MINUTES=30
ACCOUNT_BACKOFF_MINUTES=10

# -----------------------------------------------------------------------------
# Pool endurance alert thresholds
# -----------------------------------------------------------------------------
ALERT_POOL_REMAINING_HOURS_WARN=6
ALERT_POOL_REMAINING_HOURS_CRITICAL=3
ALERT_POOL_REMAINING_HOURS_EMERGENCY=1

# -----------------------------------------------------------------------------
# SMS alert switch and common options
# Leave ALERT_SMS_ENABLED=false if you only want dashboard monitoring.
# -----------------------------------------------------------------------------
ALERT_SMS_ENABLED=false
ALERT_SMS_PROVIDER=aliyun
ALERT_SMS_RECIPIENTS=
ALERT_SMS_MIN_TONE=warn
ALERT_ACCOUNT_ISSUE_THRESHOLD=1
ALERT_SMS_COOLDOWN_MINUTES=30
ALERT_SMS_TIMEOUT_SECONDS=10
ALERT_SMS_MAX_MESSAGE_CHARS=500

# -----------------------------------------------------------------------------
# Aliyun SMS provider
# Required when ALERT_SMS_ENABLED=true and ALERT_SMS_PROVIDER=aliyun.
# The SMS template should contain a variable named "content" unless changed below.
# -----------------------------------------------------------------------------
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_SMS_TEMPLATE_PARAM_NAME=content
ALIYUN_SMS_REGION_ID=cn-hangzhou
ALIYUN_SMS_ENDPOINT=https://dysmsapi.aliyuncs.com

# -----------------------------------------------------------------------------
# Webhook SMS provider
# Required when ALERT_SMS_ENABLED=true and ALERT_SMS_PROVIDER=webhook.
# -----------------------------------------------------------------------------
ALERT_SMS_WEBHOOK_URL=
ALERT_SMS_WEBHOOK_TOKEN=
